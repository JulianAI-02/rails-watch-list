<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6">
      <div class="bg-white shadow p-5 rounded">
        <h2 class="fw-bold mb-4">New List</h2>
        <%= simple_form_for(@list) do |f| %>
          <%= f.input :name, placeholder: "Drama, Sci-Fi, My Favorites..." %>
          <%= f.submit "Create List", class: "btn btn-flat w-100 mt-3" %>
        <% end %>
        <hr>
        <%= link_to "Back to overview", lists_path, class: "text-muted small text-decoration-none" %>
      </div>
    </div>
  </div>
</div>
